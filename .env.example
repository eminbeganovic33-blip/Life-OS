# Firebase Configuration
# Create a project at https://console.firebase.google.com
# 1. Create a new project
# 2. Add a web app (Project Settings > General > Your apps > Add app > Web)
# 3. Copy the config values below
# 4. Enable Authentication: Authentication > Sign-in method > Enable Email/Password + Google
# 5. Create Firestore: Firestore Database > Create database > Start in test mode

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Cloud Messaging (optional — enables background push notifications)
# 1. Enable Cloud Messaging in Firebase console: Project Settings > Cloud Messaging
# 2. Scroll to "Web configuration" and generate a Web Push certificate key pair
# 3. Copy the public VAPID key below
# Without this, the app falls back to foreground-only polling reminders.
VITE_FIREBASE_VAPID_KEY=your-public-vapid-key-here

# Gemini AI (for AI Coach features)
# Get a key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here
